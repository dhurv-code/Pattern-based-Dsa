Problem 1: Smallest Subarray Sum ≥ Target
[2,1,5,2,3,2]
target = 7

// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;
#include <climits>
int main() {
    int num[]={2,1,5,2,3,2};
    int n=sizeof(num)/sizeof(num[0]);
    int target=7;
    int left=0, sum=0;
    int ans= INT_MAX;
    for(int right=0; right<n; right++){
        sum+=num[right];
        
        while(sum>=target){
            ans=min(ans,right-left+1);
            sum-=num[left];
            left++;
        }
    }

    cout<< ans;
}

