Problem: Minimum Eating Speed??


solution:
#include <iostream>
#include <cmath>
using namespace std;

bool canFinish(int nums[], int n, int k, int h){
    int time = 0;

    for(int i = 0; i < n; i++){
        time += ceil((double)nums[i] / k);
    }

    return time <= h;
}

int main() {
    int nums[] = {3,6,7,11};
    int n = sizeof(nums)/sizeof(nums[0]);
    int h = 8;

    int left = 1;
    int right = 11;  // max element

    int ans = right;

    while(left <= right){
        int mid = left + (right - left) / 2;

        if(canFinish(nums, n, mid, h)){
            ans = mid;
            right = mid - 1;   // try smaller speed
        }
        else{
            left = mid + 1;    // need faster speed
        }
    }

    cout << ans;
    return 0;
}
