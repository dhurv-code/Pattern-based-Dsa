Backtracking =Try → Explore → Undo → Try next
this undo is back-tracking
Core Template:::::
void solve(...) {
    if(base case){
        store answer;
        return;
    }
    for(each choice){
        take choice;
        solve(smaller problem);
        undo choice;   // BACKTRACK
    }}

Problem 1: Generate All Subsets
#include <bits/stdc++.h>
using namespace std;

void solve(int i, vector<int>& arr, vector<int>& temp){
    if(i == arr.size()){
        for(int x : temp) cout << x << " ";
        cout << endl;
        return;
    }

    // take
    temp.push_back(arr[i]);
    solve(i+1, arr, temp);

    // undo
    temp.pop_back();

    // not take
    solve(i+1, arr, temp);
}

int main(){
    vector<int> arr = {1,2};
    vector<int> temp;

    solve(0, arr, temp);
}


void permute(vector<int>& nums, vector<int>& temp, vector<bool>& used){
    if(temp.size() == nums.size()){
        for(int x : temp) cout << x << " ";
        cout << endl;
        return;
    }

    for(int i=0;i<nums.size();i++){
        if(used[i]) continue;

        used[i] = true;
        temp.push_back(nums[i]);

        permute(nums, temp, used);

        temp.pop_back();
        used[i] = false;  // undo
    }
}
