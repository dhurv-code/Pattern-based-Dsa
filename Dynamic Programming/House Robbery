You are given money in houses:
[2,7,9,3,1]
Rule:
You cannot rob 2 adjacent houses
Find maximum money you can rob.

// Online C++ compiler to run C++ program online
#include <iostream>
using namespace std;
#include <vector>
int main() {
    vector<int>arr={2,7,9,3,1};
    int n=arr.size();
    
    if(n==1)return arr[0];
    
    vector<int>dp(n);
    
    dp[0]=arr[0];
    dp[1]=max(dp[0],arr[1]);
    
    for(int i=3;i<n;i++){
        dp[i]=max(dp[i-1],arr[i]+arr[i-2]);
    }
    cout<<dp[n-1];

    return 0;
}
